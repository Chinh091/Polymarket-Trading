# ============================================================
# Polymarket Paper Trading Bot - Environment Config
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- News API (free tier at newsapi.org) ---
NEWS_API_KEY=your_newsapi_key_here

# --- Anthropic API (optional - only for NewsAnalystAgent) ---
# Get from platform.anthropic.com - $5 free credit on signup
# Leave blank to run without AI news analysis (uses keyword scoring instead)
ANTHROPIC_API_KEY=

# --- Paper Trading Config ---
STARTING_BANKROLL=1000.0
MAX_POSITION_PCT=0.05
MAX_OPEN_POSITIONS=3
MAX_DRAWDOWN_PCT=0.15
TAKER_FEE=0.0156
MAKER_FEE=0.0
GAS_COST=0.02

# --- Bot Config ---
MARKET_SCAN_INTERVAL=60
NEWS_POLL_INTERVAL=60
LOG_LEVEL=INFO
